# Public client configuration for Flutter Web (Vercel: mkg-tax-mobile)
#
# Deploy credentials (Cursor Cloud / CI secrets — never commit values):
#   VERCEL_TOKEN=…
#   VERCEL_ORG_ID=team_5uxQCVdAhb1FImpmmkm9rAa5
#   VERCEL_PROJECT_ID=…   # see deploy/vercel/project.json
# Deploy: bash scripts/deploy-vercel-web.sh
# Smoke:  bash scripts/smoke-vercel-web.sh
#
# Flutter does NOT load this file at runtime. Values are supplied at build time
# via --dart-define (see scripts/build-vercel-web.sh and AppConfig).
# This file documents the ONLY public variables allowed in the browser bundle.
#
# DNS check (2026-07-20):
#   LIVE:     app.mkgtaxconsultants.com  (use for Preview)
#   NO DNS:   staging-api.finance.mkgtaxconsultants.com
#   NO DNS:   api.finance.mkgtaxconsultants.com  (intended Production — pending)
#
# Production (when finance API DNS is live):
#   API_BASE_URL=https://api.finance.mkgtaxconsultants.com/api/v1
# Preview (verified now):
#   API_BASE_URL=https://app.mkgtaxconsultants.com/api/v1
# Development:
#   API_BASE_URL=http://localhost:8000/api/v1
#   ALLOW_INSECURE_LOCAL_DEV=true

API_BASE_URL=https://app.mkgtaxconsultants.com/api/v1
LARAVEL_API_BASE_URL=https://app.mkgtaxconsultants.com
WEB_BASE_URL=https://finance.mkgtaxconsultants.com
APP_NAME=MKG Tax Consultants
APP_ENV=development

# PROHIBITED on Vercel / in the browser bundle (never set here):
# database URLs, Neon credentials, Postgres env vars, IRS MeF material,
# taxpayer encryption keys, Stripe/SendGrid/AWS/DO secrets — see
# docs/deployment/vercel-scope.md
