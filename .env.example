# Public client configuration for Flutter Web (Vercel: mkg-tax-client-web)
#
# Flutter does NOT load this file at runtime. Values are supplied at build time
# via --dart-define (see scripts/build-vercel-web.sh and AppConfig).
# This file documents the ONLY public variables allowed in the browser bundle.
#
# Equivalent Vite / Next.js names (for a future apps/web JS app only):
#   VITE_API_BASE_URL / NEXT_PUBLIC_API_BASE_URL
#   VITE_APP_NAME     / NEXT_PUBLIC_APP_NAME
#   VITE_APP_ENV      / NEXT_PUBLIC_APP_ENV
#   VITE_SUPPORT_URL  / NEXT_PUBLIC_SUPPORT_URL
# Do not put secrets in VITE_*, NEXT_PUBLIC_*, or dart-defines.
#
# Production:
#   API_BASE_URL=https://api.finance.mkgtaxconsultants.com/api/v1
# Preview:
#   API_BASE_URL=https://staging-api.finance.mkgtaxconsultants.com/api/v1
# Development:
#   API_BASE_URL=http://localhost:8000/api/v1
#   ALLOW_INSECURE_LOCAL_DEV=true

API_BASE_URL=https://staging-api.finance.mkgtaxconsultants.com/api/v1
LARAVEL_API_BASE_URL=https://staging-api.finance.mkgtaxconsultants.com
WEB_BASE_URL=https://finance.mkgtaxconsultants.com
APP_NAME=MKG Tax Consultants
APP_ENV=development

# PROHIBITED on Vercel / in the browser bundle (never set here):
# DATABASE_URL
# NEON_DATABASE_URL
# PGHOST / PGUSER / PGPASSWORD / PGDATABASE
# IRS_MEF_PRIVATE_KEY / IRS_MEF_CERTIFICATE / IRS_MEF_CERTIFICATE_PASSWORD
# SSN_ENCRYPTION_KEY / TAXPAYER_ENCRYPTION_KEY
# APP_KEY / JWT_PRIVATE_KEY
# DIGITALOCEAN_ACCESS_TOKEN / AWS_SECRET_ACCESS_KEY
# STRIPE_SECRET_KEY / SENDGRID_API_KEY
