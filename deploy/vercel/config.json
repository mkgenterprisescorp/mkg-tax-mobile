{
  "version": 3,
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "headers": { "cache-control": "public, max-age=604800, immutable" },
      "continue": true
    },
    {
      "src": "^/canvaskit/(.*)$",
      "headers": { "cache-control": "public, max-age=604800, immutable" },
      "continue": true
    },
    {
      "src": "^/(.*\\.(js|mjs|wasm|png|jpg|jpeg|gif|svg|ico|ttf|otf|woff|woff2))$",
      "headers": { "cache-control": "public, max-age=86400" },
      "continue": true
    },
    {
      "src": "^/(index\\.html|flutter_service_worker\\.js|manifest\\.json|version\\.json)$",
      "headers": { "cache-control": "no-store" },
      "continue": true
    },
    { "handle": "filesystem" },
    {
      "src": "^/(.*)$",
      "headers": { "cache-control": "no-store" },
      "dest": "/index.html"
    }
  ]
}
