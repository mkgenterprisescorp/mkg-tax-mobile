# INSTALL: copy this file to `.github/workflows/flutter-ios-testflight.yml`.
# A Personal Access Token without the GitHub `workflow` scope cannot push
# files under `.github/workflows/`. Owner/admin: copy then commit with a
# token or account that has the `workflow` scope (or use the GitHub UI).
#
# Do not enable until the ios-testflight Environment secrets/vars are set
# and required reviewers are configured. Never run for pull_request.
#
name: Flutter iOS TestFlight (signed)

# Manual signed IPA pipeline. Never runs on pull_request / forks.
# Requires GitHub Environment `ios-testflight` with required reviewers.
# Upload to TestFlight only when upload_to_testflight=true AND environment is approved.
#
# Xcode still runs on the GitHub-hosted macOS runner — this workflow does not
# avoid Xcode; it avoids needing a local Mac for ordinary CI builds.

on:
  workflow_dispatch:
    inputs:
      release_notes:
        description: TestFlight / artifact release notes (no secrets)
        required: false
        default: "Staging TestFlight candidate"
      api_environment:
        description: API environment (staging only for now)
        required: true
        default: staging
        type: choice
        options:
          - staging
      upload_to_testflight:
        description: Upload IPA to App Store Connect / TestFlight after checks
        required: true
        default: false
        type: boolean
      build_name:
        description: CFBundleShortVersionString override (blank = pubspec version name)
        required: false
        default: ""
      build_number_offset:
        description: Added to github.run_number for CFBundleVersion (monotonic)
        required: false
        default: "0"

permissions:
  contents: read

concurrency:
  group: flutter-ios-testflight-${{ github.ref }}
  cancel-in-progress: false

env:
  FLUTTER_VERSION: "3.44.6"
  STAGING_LARAVEL_ORIGIN: "https://app.mkgtaxconsultants.com"
  # Non-secret defaults; overridden by environment vars when set.
  STAGING_API_BASE_URL: ${{ vars.STAGING_API_BASE_URL || 'https://app.mkgtaxconsultants.com/api/v1' }}
  IOS_BUNDLE_ID: ${{ vars.IOS_BUNDLE_ID }}
  APPLE_TEAM_ID: ${{ vars.APPLE_TEAM_ID }}
  IOS_EXPORT_METHOD: ${{ vars.IOS_EXPORT_METHOD || 'app-store-connect' }}
  IOS_PROVISIONING_PROFILE_NAME: ${{ vars.IOS_PROVISIONING_PROFILE_NAME }}

jobs:
  signed-ipa:
    name: Signed IPA (+ optional TestFlight)
    runs-on: macos-14
    timeout-minutes: 90
    environment: ios-testflight
    steps:
      - name: Checkout
        uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2

      - name: Restrict API environment to staging
        run: |
          set -euo pipefail
          if [ "${{ inputs.api_environment }}" != "staging" ]; then
            echo "::error::Only staging is permitted in this workflow."
            exit 1
          fi

      - name: Validate required secrets/variables (fail closed)
        env:
          IOS_DISTRIBUTION_CERTIFICATE_BASE64: ${{ secrets.IOS_DISTRIBUTION_CERTIFICATE_BASE64 }}
          IOS_DISTRIBUTION_CERTIFICATE_PASSWORD: ${{ secrets.IOS_DISTRIBUTION_CERTIFICATE_PASSWORD }}
          IOS_PROVISIONING_PROFILE_BASE64: ${{ secrets.IOS_PROVISIONING_PROFILE_BASE64 }}
          IOS_KEYCHAIN_PASSWORD: ${{ secrets.IOS_KEYCHAIN_PASSWORD }}
          APP_STORE_CONNECT_API_KEY_BASE64: ${{ secrets.APP_STORE_CONNECT_API_KEY_BASE64 }}
          APP_STORE_CONNECT_KEY_ID: ${{ secrets.APP_STORE_CONNECT_KEY_ID }}
          APP_STORE_CONNECT_ISSUER_ID: ${{ secrets.APP_STORE_CONNECT_ISSUER_ID }}
        run: |
          chmod +x scripts/ci/ios_require_secrets.sh
          ./scripts/ci/ios_require_secrets.sh

      - name: Refuse production / credential leakage markers
        run: |
          set -euo pipefail
          for var in DATABASE_URL NEON_DATABASE_URL HMAC_SECRET IDENTITY_ASSERTION_SECRET MOCK_PASSWORD; do
            if [ -n "${!var:-}" ]; then
              echo "::error::Refuse: ${var} must not be present in iOS TestFlight job env."
              exit 1
            fi
          done
          case "${STAGING_API_BASE_URL}" in
            https://app.mkgtaxconsultants.com/api/v1) ;;
            *)
              echo "::error::STAGING_API_BASE_URL must be https://app.mkgtaxconsultants.com/api/v1 for this workflow."
              exit 1
              ;;
          esac

      - name: Staging API smoke gates
        env:
          IOS_STAGING_TEST_IDENTIFIER: ${{ secrets.IOS_STAGING_TEST_IDENTIFIER }}
          IOS_STAGING_TEST_PASSWORD: ${{ secrets.IOS_STAGING_TEST_PASSWORD }}
        run: |
          chmod +x scripts/ci/ios_staging_smoke.sh
          ./scripts/ci/ios_staging_smoke.sh

      - name: Set up Flutter
        uses: subosito/flutter-action@1a449444c387b1966244ae4d4f8c696479add0b2 # v2.23.0
        with:
          flutter-version: ${{ env.FLUTTER_VERSION }}
          channel: stable
          cache: true

      - name: Print toolchain versions (no secrets)
        run: |
          set -euo pipefail
          echo "Flutter: $(flutter --version | head -n 1)"
          echo "Dart: $(dart --version 2>&1)"
          echo "Xcode: $(xcodebuild -version | tr '\n' ' ')"

      - name: flutter pub get
        run: flutter pub get

      - name: flutter analyze
        run: flutter analyze lib test

      - name: flutter test
        run: flutter test --concurrency=1

      - name: Import signing certificate into temporary keychain
        id: keychain
        env:
          IOS_DISTRIBUTION_CERTIFICATE_BASE64: ${{ secrets.IOS_DISTRIBUTION_CERTIFICATE_BASE64 }}
          IOS_DISTRIBUTION_CERTIFICATE_PASSWORD: ${{ secrets.IOS_DISTRIBUTION_CERTIFICATE_PASSWORD }}
          IOS_KEYCHAIN_PASSWORD: ${{ secrets.IOS_KEYCHAIN_PASSWORD }}
        run: |
          set -euo pipefail
          CERT_PATH="${RUNNER_TEMP}/ios_dist.p12"
          KEYCHAIN_PATH="${RUNNER_TEMP}/mkg-ios-signing.keychain-db"
          echo "${IOS_DISTRIBUTION_CERTIFICATE_BASE64}" | base64 --decode > "${CERT_PATH}"
          security create-keychain -p "${IOS_KEYCHAIN_PASSWORD}" "${KEYCHAIN_PATH}"
          security set-keychain-settings -lut 21600 "${KEYCHAIN_PATH}"
          security unlock-keychain -p "${IOS_KEYCHAIN_PASSWORD}" "${KEYCHAIN_PATH}"
          security import "${CERT_PATH}" -P "${IOS_DISTRIBUTION_CERTIFICATE_PASSWORD}" \
            -A -t cert -f pkcs12 -k "${KEYCHAIN_PATH}"
          security list-keychains -d user -s "${KEYCHAIN_PATH}" $(security list-keychains -d user | sed -e s/\"//g)
          security set-key-partition-list -S apple-tool:,apple:,codesign: -s \
            -k "${IOS_KEYCHAIN_PASSWORD}" "${KEYCHAIN_PATH}" >/dev/null
          echo "keychain_path=${KEYCHAIN_PATH}" >> "$GITHUB_OUTPUT"
          echo "cert_path=${CERT_PATH}" >> "$GITHUB_OUTPUT"
          rm -f "${CERT_PATH}"
          echo "Distribution certificate imported into temporary keychain (material not printed)."

      - name: Install provisioning profile
        id: profile
        env:
          IOS_PROVISIONING_PROFILE_BASE64: ${{ secrets.IOS_PROVISIONING_PROFILE_BASE64 }}
        run: |
          set -euo pipefail
          PP_PATH="${RUNNER_TEMP}/profile.mobileprovision"
          echo "${IOS_PROVISIONING_PROFILE_BASE64}" | base64 --decode > "${PP_PATH}"
          UUID="$(security cms -D -i "${PP_PATH}" | plutil -extract UUID raw -o - -)"
          mkdir -p "${HOME}/Library/MobileDevice/Provisioning Profiles"
          cp "${PP_PATH}" "${HOME}/Library/MobileDevice/Provisioning Profiles/${UUID}.mobileprovision"
          echo "uuid=${UUID}" >> "$GITHUB_OUTPUT"
          echo "path=${PP_PATH}" >> "$GITHUB_OUTPUT"
          if [ -z "${IOS_PROVISIONING_PROFILE_NAME:-}" ]; then
            NAME="$(security cms -D -i "${PP_PATH}" | plutil -extract Name raw -o - -)"
            echo "IOS_PROVISIONING_PROFILE_NAME=${NAME}" >> "$GITHUB_ENV"
            echo "Resolved provisioning profile display name from profile metadata."
          fi

      - name: Resolve build name / number
        id: version
        run: |
          set -euo pipefail
          PUBSPEC_NAME="$(awk '/^version:/ {print $2}' pubspec.yaml | cut -d+ -f1)"
          BUILD_NAME="${{ inputs.build_name }}"
          if [ -z "${BUILD_NAME}" ]; then BUILD_NAME="${PUBSPEC_NAME}"; fi
          OFFSET="${{ inputs.build_number_offset }}"
          RUN_NUMBER="${{ github.run_number }}"
          BUILD_NUMBER=$(( RUN_NUMBER + OFFSET ))
          echo "build_name=${BUILD_NAME}" >> "$GITHUB_OUTPUT"
          echo "build_number=${BUILD_NUMBER}" >> "$GITHUB_OUTPUT"
          echo "Using CFBundleShortVersionString=${BUILD_NAME} CFBundleVersion=${BUILD_NUMBER}"

      - name: Confirm Xcode bundle ID matches environment
        run: |
          set -euo pipefail
          CURRENT_BID="$(python3 - <<'PY'
          import re
          text=open("ios/Runner.xcodeproj/project.pbxproj").read()
          # Prefer Runner target Release setting (last PRODUCT_BUNDLE_IDENTIFIER for Runner app configs).
          ids=re.findall(r"PRODUCT_BUNDLE_IDENTIFIER = ([^;]+);", text)
          # Filter out RunnerTests
          app=[i for i in ids if "RunnerTests" not in i]
          print(app[0].strip() if app else "")
          PY
          )"
          echo "Xcode PRODUCT_BUNDLE_IDENTIFIER=${CURRENT_BID}"
          echo "Environment IOS_BUNDLE_ID=${IOS_BUNDLE_ID}"
          if [ -z "${IOS_BUNDLE_ID}" ]; then
            echo "::error::IOS_BUNDLE_ID environment variable is empty. Owner must set it in ios-testflight."
            exit 1
          fi
          if [ "${CURRENT_BID}" != "${IOS_BUNDLE_ID}" ]; then
            echo "::error::Bundle ID mismatch between ios/Runner project (${CURRENT_BID}) and ios-testflight var IOS_BUNDLE_ID (${IOS_BUNDLE_ID}). Align App Store Connect / Xcode before signing. Suggested future ID (owner confirmation required, not auto-registered): com.mkgtaxconsultants.mobile"
            exit 1
          fi

      - name: Generate ExportOptions.plist
        run: |
          set -euo pipefail
          METHOD="${IOS_EXPORT_METHOD}"
          if [ "${METHOD}" = "app-store" ]; then METHOD="app-store-connect"; fi
          if [ -z "${IOS_PROVISIONING_PROFILE_NAME:-}" ]; then
            echo "::error::IOS_PROVISIONING_PROFILE_NAME is empty after profile install."
            exit 1
          fi
          export METHOD
          python3 - <<'PY'
          import os
          from pathlib import Path
          method = os.environ["METHOD"]
          team = os.environ["APPLE_TEAM_ID"]
          bid = os.environ["IOS_BUNDLE_ID"]
          profile = os.environ["IOS_PROVISIONING_PROFILE_NAME"]
          path = Path(os.environ["RUNNER_TEMP"]) / "ExportOptions.plist"
          path.write_text(
              '<?xml version="1.0" encoding="UTF-8"?>\n'
              '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" '
              '"http://www.apple.com/DTDs/PropertyList-1.0.dtd">\n'
              '<plist version="1.0">\n<dict>\n'
              f'  <key>method</key><string>{method}</string>\n'
              '  <key>signingStyle</key><string>manual</string>\n'
              f'  <key>teamID</key><string>{team}</string>\n'
              '  <key>uploadSymbols</key><true/>\n'
              '  <key>manageAppVersionAndBuildNumber</key><false/>\n'
              '  <key>provisioningProfiles</key>\n  <dict>\n'
              f'    <key>{bid}</key><string>{profile}</string>\n'
              '  </dict>\n</dict>\n</plist>\n'
          )
          if "PLACEHOLDER" in path.read_text():
              raise SystemExit("ExportOptions still contains PLACEHOLDER values")
          print("ExportOptions.plist generated (values not echoed).")
          PY

      - name: Apply ephemeral manual signing settings (CI workspace only)
        run: |
          set -euo pipefail
          # Ephemeral edits for the runner workspace — never committed.
          python3 - <<'PY'
          from pathlib import Path
          import os, re
          path = Path("ios/Runner.xcodeproj/project.pbxproj")
          text = path.read_text()
          team = os.environ["APPLE_TEAM_ID"]
          # Ensure Release/Profile Runner configs use Manual + team.
          def inject(settings_block: str) -> str:
              if "CODE_SIGN_STYLE" not in settings_block:
                  settings_block = settings_block.replace(
                      "buildSettings = {",
                      "buildSettings = {\n\t\t\t\tCODE_SIGN_STYLE = Manual;",
                      1,
                  )
              else:
                  settings_block = re.sub(
                      r"CODE_SIGN_STYLE = [^;]+;",
                      "CODE_SIGN_STYLE = Manual;",
                      settings_block,
                  )
              if "DEVELOPMENT_TEAM" not in settings_block:
                  settings_block = settings_block.replace(
                      "CODE_SIGN_STYLE = Manual;",
                      f"CODE_SIGN_STYLE = Manual;\n\t\t\t\tDEVELOPMENT_TEAM = {team};",
                      1,
                  )
              else:
                  settings_block = re.sub(
                      r"DEVELOPMENT_TEAM = [^;]+;",
                      f"DEVELOPMENT_TEAM = {team};",
                      settings_block,
                  )
              return settings_block
          # Conservative: set project-level DEVELOPMENT_TEAM if absent.
          if "DEVELOPMENT_TEAM" not in text:
              text = text.replace(
                  "IPHONEOS_DEPLOYMENT_TARGET = 13.0;",
                  f"IPHONEOS_DEPLOYMENT_TARGET = 13.0;\n\t\t\t\tDEVELOPMENT_TEAM = {team};",
              )
          path.write_text(text)
          print("Ephemeral CODE_SIGN_STYLE/DEVELOPMENT_TEAM adjustments applied for CI only.")
          PY

      - name: flutter build ipa --release
        run: |
          set -euo pipefail
          flutter build ipa --release \
            --build-name="${{ steps.version.outputs.build_name }}" \
            --build-number="${{ steps.version.outputs.build_number }}" \
            --export-options-plist="${RUNNER_TEMP}/ExportOptions.plist" \
            --dart-define=API_BASE_URL="${STAGING_API_BASE_URL}" \
            --dart-define=LARAVEL_API_BASE_URL="${STAGING_LARAVEL_ORIGIN}" \
            --dart-define=APP_ENV=preview \
            --dart-define=APP_NAME="MKG Tax Consultants (Staging)"

      - name: Locate IPA
        id: ipa
        run: |
          set -euo pipefail
          IPA="$(find build/ios/ipa -type f -name '*.ipa' | head -n 1)"
          if [ -z "${IPA}" ]; then
            echo "::error::IPA not produced under build/ios/ipa"
            find build/ios -maxdepth 4 -type f -print || true
            exit 1
          fi
          echo "path=${IPA}" >> "$GITHUB_OUTPUT"
          ls -lh "${IPA}"

      - name: Inspect IPA + secret scan
        run: |
          chmod +x scripts/ci/ios_inspect_and_scan_ipa.sh
          ./scripts/ci/ios_inspect_and_scan_ipa.sh "${{ steps.ipa.outputs.path }}"

      - name: Upload IPA artifact (private, short retention)
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4.6.2
        with:
          name: mkg-tax-mobile-ios-staging-ipa
          path: ${{ steps.ipa.outputs.path }}
          retention-days: 7
          if-no-files-found: error

      - name: Install App Store Connect API key (temporary)
        if: ${{ inputs.upload_to_testflight }}
        env:
          APP_STORE_CONNECT_API_KEY_BASE64: ${{ secrets.APP_STORE_CONNECT_API_KEY_BASE64 }}
          APP_STORE_CONNECT_KEY_ID: ${{ secrets.APP_STORE_CONNECT_KEY_ID }}
        run: |
          set -euo pipefail
          KEY_DIR="${HOME}/.appstoreconnect/private_keys"
          mkdir -p "${KEY_DIR}"
          KEY_PATH="${KEY_DIR}/AuthKey_${APP_STORE_CONNECT_KEY_ID}.p8"
          echo "${APP_STORE_CONNECT_API_KEY_BASE64}" | base64 --decode > "${KEY_PATH}"
          chmod 600 "${KEY_PATH}"
          echo "ASC_KEY_ID=${APP_STORE_CONNECT_KEY_ID}" >> "$GITHUB_ENV"
          echo "App Store Connect API key installed to temporary runner path (contents not printed)."

      - name: Upload to TestFlight
        if: ${{ inputs.upload_to_testflight }}
        env:
          APP_STORE_CONNECT_KEY_ID: ${{ secrets.APP_STORE_CONNECT_KEY_ID }}
          APP_STORE_CONNECT_ISSUER_ID: ${{ secrets.APP_STORE_CONNECT_ISSUER_ID }}
          RELEASE_NOTES: ${{ inputs.release_notes }}
        run: |
          set -euo pipefail
          echo "Uploading IPA to App Store Connect / TestFlight (notes length=${#RELEASE_NOTES})."
          xcrun altool --upload-app \
            --type ios \
            --file "${{ steps.ipa.outputs.path }}" \
            --apiKey "${APP_STORE_CONNECT_KEY_ID}" \
            --apiIssuer "${APP_STORE_CONNECT_ISSUER_ID}"

      - name: Skip TestFlight upload
        if: ${{ !inputs.upload_to_testflight }}
        run: echo "upload_to_testflight=false — IPA artifact retained in GitHub Actions only."

      - name: Always cleanup signing material
        if: always()
        env:
          APP_STORE_CONNECT_KEY_ID: ${{ secrets.APP_STORE_CONNECT_KEY_ID }}
        run: |
          set +e
          KEYCHAIN_PATH="${{ steps.keychain.outputs.keychain_path }}"
          if [ -n "${KEYCHAIN_PATH}" ] && [ -f "${KEYCHAIN_PATH}" ]; then
            security delete-keychain "${KEYCHAIN_PATH}" 2>/dev/null
          fi
          rm -f "${{ steps.keychain.outputs.cert_path }}"
          rm -f "${{ steps.profile.outputs.path }}"
          if [ -n "${{ steps.profile.outputs.uuid }}" ]; then
            rm -f "${HOME}/Library/MobileDevice/Provisioning Profiles/${{ steps.profile.outputs.uuid }}.mobileprovision"
          fi
          rm -f "${HOME}/.appstoreconnect/private_keys/AuthKey_${APP_STORE_CONNECT_KEY_ID:-}.p8"
          rm -f "${RUNNER_TEMP}/ExportOptions.plist" "${RUNNER_TEMP}/ios_dist.p12" "${RUNNER_TEMP}/profile.mobileprovision"
          echo "Signing materials cleaned from runner."
